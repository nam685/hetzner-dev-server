#!/usr/bin/env bash
# new-claude — Open a new Zellij tab with claude panes
# Computer: 3 panes — claude | shell / logs
# Phone (session "phone"): runs claude in current pane
# Also kills the "coding" Zellij session if it exists.
# Usage: new-claude [/path/to/worktree]

set -euo pipefail

DIR="${1:-$HOME}"
DIR="$(cd "$DIR" 2>/dev/null && pwd)" || { echo "Directory not found: $1"; exit 1; }
NAME="$(basename "$DIR")"

if [ -z "${ZELLIJ:-}" ]; then
    echo "Not in a Zellij session. Run 'zellij' first."
    exit 1
fi

# Kill "coding" session if it exists (ignore errors)
zellij kill-session coding 2>/dev/null || true

# Phone: just run claude in the current pane (no extra tabs)
if [ "${ZELLIJ_SESSION_NAME:-}" = "phone" ]; then
    cd "$DIR"
    exec claude
fi

# Computer: 3 panes
LAYOUT_FILE="${TMPDIR:-/tmp}/new-claude-layout.kdl"
cat > "$LAYOUT_FILE" <<'KDL'
layout {
    tab_template name="default" {
        pane size=1 borderless=true {
            plugin location="tab-bar"
        }
        children
        pane size=2 borderless=true {
            plugin location="status-bar"
        }
    }
    default name="claude" {
        pane split_direction="vertical" {
            pane name="claude" size="60%" focus=true command="claude"
            pane split_direction="horizontal" {
                pane name="shell"
                pane name="logs"
            }
        }
    }
}
KDL

zellij action new-tab --layout "$LAYOUT_FILE" --name "$NAME" --cwd "$DIR"
rm -f "$LAYOUT_FILE"
echo "New tab '$NAME' → $DIR"
